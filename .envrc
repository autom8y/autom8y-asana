#!/usr/bin/env bash
set -o errexit
set -o pipefail

watch_file pyproject.toml

# devbox -- pin dev-critical tools via Nix
if has devbox; then
  eval "$(devbox generate direnv --print-envrc)"
fi

use autom8y --no-tf
autom8y_tf_bridge_all "ASANA_PAT:asana_pat" "ASANA_WORKSPACE_GID:asana_workspace_gid"
