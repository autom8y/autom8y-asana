#!/usr/bin/env bash
set -o errexit
set -o pipefail

autom8y_load_env
autom8y_get_codeartifact_token

# Terraform variable bridging (asana-specific)
[ -n "${ASANA_PAT:-}" ]           && export TF_VAR_asana_pat="$ASANA_PAT" || true
[ -n "${ASANA_WORKSPACE_GID:-}" ] && export TF_VAR_asana_workspace_gid="$ASANA_WORKSPACE_GID" || true
