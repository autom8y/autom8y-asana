#!/usr/bin/env bash
set -o errexit
set -o pipefail

watch_file pyproject.toml

# devbox -- pin dev-critical tools via Nix
if has devbox; then
  eval "$(devbox generate direnv --print-envrc)"
fi

# >>> a8 stdlib self-heal — managed; see a8/scripts/a8-devenv-install.sh >>>
# If the direnv stdlib extension (~/.config/direnv/lib/a8.sh) is not installed, discover
# the a8 checkout by walking up from $PWD and source the library directly. If the library
# still cannot provide a resolvable ecosystem config, fail with EX_CONFIG (78) and a clear
# remediation instead of a bare exit-127 (use_<org>: command not found). errexit/bash-3.2 safe.
if ! declare -f use_a8 >/dev/null 2>&1; then
  _a8_seek="$PWD"
  while [ "$_a8_seek" != "/" ] && [ ! -f "$_a8_seek/scripts/a8-devenv.sh" ]; do
    _a8_seek="$(dirname "$_a8_seek")"
  done
  if [ -f "$_a8_seek/scripts/a8-devenv.sh" ]; then . "$_a8_seek/scripts/a8-devenv.sh"; fi
  unset _a8_seek
fi
if ! declare -f use_a8 >/dev/null 2>&1 || ! _a8_resolve_config >/dev/null 2>&1; then
  printf 'a8: direnv stdlib not provisioned — direnv would fail (exit 127).\n' >&2
  printf 'a8:   fix: cd ~/Code/a8 && bash scripts/a8-devenv-install.sh && direnv allow\n' >&2
  exit 78
fi
# <<< a8 stdlib self-heal <<<

use autom8y --no-tf
autom8y_tf_bridge_all "ASANA_PAT:asana_pat" "ASANA_WORKSPACE_GID:asana_workspace_gid"
