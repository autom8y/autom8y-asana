{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(python3 -m py_compile:*)",
      "Bash(mkdir:*)",
      "Skill(initiative-scoping)",
      "Skill(prompting)",
      "Skill(10x-workflow)",
      "Skill(documentation)",
      "Skill(atuin-desktop)",
      "Skill(consult-ref)",
      "Bash(time zsh:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(zsh:*)",
      "Bash(for i in 1 2 3 4 5)",
      "Bash(do /usr/bin/time zsh -i -c exit)",
      "Bash(done)",
      "Bash(command -v mise:*)",
      "Bash(mise --version:*)",
      "Bash(command -v nvm:*)",
      "Bash(nvm --version:*)",
      "Bash(command -v:*)",
      "Bash(pyenv --version:*)",
      "Bash(rbenv:*)",
      "Bash(direnv:*)",
      "Bash(zoxide --version:*)",
      "Bash(atuin:*)",
      "Bash(fzf:*)",
      "Bash(command -v eza:*)",
      "Bash(eza:*)",
      "Bash(command:*)",
      "Bash(bat:*)",
      "Bash(delta:*)",
      "Bash(cut:*)",
      "Bash(brew install:*)",
      "Bash(starship --version:*)",
      "Bash(/bin/zsh -c 'source ~/.zshrc')",
      "Bash(for i in {1..5})",
      "Bash(do /bin/zsh -i -c exit)",
      "Bash(do )",
      "Bash(/usr/bin/time:*)",
      "Bash(grep:*)",
      "Bash(source ~/.zshrc)",
      "Bash(env)",
      "Bash(echo:*)",
      "Bash(mise settings:*)",
      "Bash(mise doctor:*)",
      "Bash(mise list:*)",
      "Bash(brew list:*)",
      "Bash(source /Users/tomtenuta/.zshrc)",
      "Bash(file:*)",
      "Bash(mise use:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(du:*)",
      "Bash(test:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(basename:*)",
      "Bash(head:*)",
      "Bash(sed:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(ls ~/Code/roster/teams/:*)",
      "Bash(ls .claude/agents/:*)",
      "Bash(~/Code/roster/swap-team.sh:*)",
      "Bash(openssl:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(date:*)",
      "Bash(awk:*)",
      "Bash(mkdir:*)",
      "Bash(.claude/hooks/lib/session-manager.sh:*)",
      "Bash(.claude/hooks/lib/worktree-manager.sh:*)"
    ],
    "additionalDirectories": [
      "~/Code/roster"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "go-semantic",
    "typescript-semantic",
    "mermaid-mcp"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-context.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/coach-mode.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto-park.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/artifact-tracker.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-audit.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/commit-tracker.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/command-validator.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-write-guard.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/delegation-check.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/start-preflight.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
