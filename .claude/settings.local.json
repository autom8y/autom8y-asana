{
  "enabledMcpjsonServers": [
    "go-semantic",
    "mermaid-mcp",
    "typescript-semantic"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "async": true,
            "command": "ari hook clew --output json",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|Bash"
      },
      {
        "hooks": [
          {
            "command": "ari hook budget --output json",
            "timeout": 3,
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "ari hook precompact --output json",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "ari hook writeguard --output json",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "ari hook validate --output json",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "ari hook sessionend --output json",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "ari hook context --output json",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "ari hook autopark --output json",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "async": true,
            "command": "ari hook subagent-start --output json",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "ari hook subagent-stop --output json",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "github": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "command": "npx",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  },
  "permissions": {
    "additionalDirectories": [
      "~/Code/roster"
    ],
    "allow": [
      "Bash(.claude/hooks/lib/session-manager.sh:*)",
      "Bash(.claude/hooks/lib/worktree-manager.sh:*)",
      "Bash(/bin/zsh -c 'source ~/.zshrc')",
      "Bash(/usr/bin/time:*)",
      "Bash(atuin:*)",
      "Bash(awk:*)",
      "Bash(basename:*)",
      "Bash(bat:*)",
      "Bash(brew install:*)",
      "Bash(brew list:*)",
      "Bash(cat:*)",
      "Bash(command -v eza:*)",
      "Bash(command -v mise:*)",
      "Bash(command -v nvm:*)",
      "Bash(command -v:*)",
      "Bash(command:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(delta:*)",
      "Bash(direnv:*)",
      "Bash(do )",
      "Bash(do /bin/zsh -i -c exit)",
      "Bash(do /usr/bin/time zsh -i -c exit)",
      "Bash(done)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(env)",
      "Bash(eza:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(for i in 1 2 3 4 5)",
      "Bash(for i in {1..5})",
      "Bash(fzf:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls .claude/agents/:*)",
      "Bash(ls ~/Code/roster/teams/:*)",
