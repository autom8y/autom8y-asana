# autom8y-asana Runbook Environment
# =================================
#
# Location: ~/.config/autom8y/envs/autom8y-asana/runbook.env
#
# SETUP:
# 1. Run: just setup-env (creates this file)
# 2. Add your ASANA_PAT (Personal Access Token from Asana)
#
# Environment is automatically loaded by justfile runbook commands.
# No direnv required.

# ============================================
# Required Variables
# ============================================

# Asana Personal Access Token
# Get from: https://app.asana.com/0/my-apps
export ASANA_PAT=""

# ============================================
# API Configuration
# ============================================

# API server host (default: 0.0.0.0 for container compatibility)
export API_HOST="0.0.0.0"

# API server port
export API_PORT="8000"

# Logging level (DEBUG, INFO, WARNING, ERROR)
export LOG_LEVEL="INFO"

# ============================================
# Optional: Auth Integration
# ============================================
# Required only if integrating with autom8y auth service

# Auth service (token provider)
# export AUTH_BASE_URL="https://auth.api.autom8y.io"

# ServiceAccount credentials (from Auth service onboarding)
# export SERVICE_CLIENT_ID=""
# export SERVICE_CLIENT_SECRET=""

# Business context UUID (from Auth service onboarding)
# export DEFAULT_BUSINESS_ID=""

# ============================================
# Optional: Redis Cache
# ============================================
# Required only if using Redis-backed caching

# Redis connection URL
# export REDIS_URL="redis://localhost:6379/0"

# Cache TTL in seconds (default: 300)
# export CACHE_TTL="300"
