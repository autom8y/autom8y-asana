# ~/Code/autom8y-asana/Dockerfile.dev
# Dev image for asana service. Installs public PyPI deps only.
# SDKs are provided via volume mount at /app/sdks/.
# See TDD-LOCAL-DEV-ENV.md Section 4.3

FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl gcc && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install public dependencies only (no autom8y-* packages).
# Uses uv export --frozen to read the full transitive dep graph from uv.lock
# (no index access needed), then filters out private packages.
# UV_NO_CONFIG=1 prevents uv from reading [tool.uv] CodeArtifact config.
COPY pyproject.toml uv.lock ./
RUN uv export --frozen --format requirements-txt --no-hashes \
    --no-dev --no-emit-project \
    --extra redis --extra api --extra auth \
    | grep -v '^autom8[y-]' > /tmp/requirements.txt && \
    UV_NO_CONFIG=1 uv pip install --system -r /tmp/requirements.txt

# Install the service package itself (without its autom8y deps)
COPY src ./src
RUN UV_NO_CONFIG=1 uv pip install --system --no-deps .

# SDK source will be volume-mounted at /app/sdks/
ENV PYTHONPATH="/app/sdks:/app/src:${PYTHONPATH:-}"

EXPOSE 8000

CMD ["uvicorn", "autom8_asana.api.main:create_app", "--factory", \
     "--host", "0.0.0.0", "--port", "8000", \
     "--reload", "--reload-dir", "/app/src", "--reload-dir", "/app/sdks"]
